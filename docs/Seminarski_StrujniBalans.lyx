\begin_layout Subsection
Parsiranje MATPOWER formata
\end_layout

\begin_layout Standard
Ulazna 
\family typewriter
.m
\family default
 datoteka sadrži baznu snagu 
\family typewriter
baseMVA
\family default
 i tri matrice: 
\family typewriter
bus
\family default
 (čvorovi: tip, opterećenje 
\begin_inset Formula $P_d,Q_d$
\end_inset

, otočni 
\begin_inset Formula $G_s,B_s$
\end_inset

, početni napon), 
\family typewriter
gen
\family default
 (generatori: čvor, 
\begin_inset Formula $P_g,Q_g$
\end_inset

, zadani 
\begin_inset Formula $|V|$
\end_inset

) i 
\family typewriter
branch
\family default
 (grane: 
\begin_inset Formula $r$
\end_inset

, 
\begin_inset Formula $x$
\end_inset

, 
\begin_inset Formula $b$
\end_inset

, prijenosni odnos 
\begin_inset Formula $t$
\end_inset

 i fazni pomak 
\begin_inset Formula $\varphi$
\end_inset

). Parser tolerira komentare i razmake, numeraciju čvorova preslikava u kontinuirane indekse, a sve snage normalizuje na p.u.
\begin_inset space \space{}

\end_inset

dijeljenjem sa 
\family typewriter
baseMVA
\family default
. Injekcija čvora računa se kao razlika generacije i potrošnje, 
\begin_inset Formula $P_i = P_{g,i}-P_{d,i}$
\end_inset

, 
\begin_inset Formula $Q_i = Q_{g,i}-Q_{d,i}$
\end_inset

.
\end_layout

\begin_layout Subsection
Izgradnja Y-bus matrice
\end_layout

\begin_layout Standard
Y-bus se gradi jednim prolazom kroz listu grana prema 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:ybus"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

, u kompleksnoj natID matrici 
\family typewriter
dense::CmplxMatrix
\family default
; otočni elementi čvorova dodaju se na dijagonalu u drugom prolazu. Za ciljne dimenzije zadatka (deseci do stotine čvorova) gusta reprezentacija je jednostavna i dovoljno brza, a prelazak na rijetku strukturu ostaje otvoren pravac za veće sisteme (poglavlje
\begin_inset space ~

\end_inset


\begin_inset CommandInset ref
LatexCommand ref
reference "sec:diskusija"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

).
\end_layout

\begin_layout Subsection
Generisanje 
\family typewriter
.dmodl
\family default
 modela
\end_layout

\begin_layout Standard
Izlaz je tekstualni dTwin NL model: promjenljive (
\begin_inset Formula $\delta_i$
\end_inset

, 
\begin_inset Formula $V_i$
\end_inset

, te 
\begin_inset Formula $Q_i^g$
\end_inset

 za PV čvorove), parametri i po dvije jednačine strujnog balansa po čvoru. Primjer za PQ čvor 5 (skraćeno): 
\size small

\end_layout

\begin_layout Verbatim
Y_5_5*V_5*cos(th_5_5+d_5)+... = (P_5*cos(d_5)+Q_5*sin(d_5))/V_5
\end_layout

\begin_layout Verbatim
Y_5_5*V_5*sin(th_5_5+d_5)+... = (P_5*sin(d_5)-Q_5*cos(d_5))/V_5
\end_layout

\begin_layout Standard
 
\begin_inset ERT
status collapsed

\begin_layout Plain Layout

\backslash
noindent
\end_layout

\end_inset

 (u stvarnom modelu koriste se UTF-8 simboli: 
\begin_inset Formula $\theta$
\end_inset

 umjesto 
\family typewriter
th
\family default
, 
\begin_inset Formula $\delta$
\end_inset

 umjesto 
\family typewriter
d
\family default
). Numeričke konstante ispisuju se s punom dvostrukom preciznošću, kako konverzija ne bi unijela gubitak tačnosti.
\end_layout

\begin_layout Subsection
Višenitnost i grafički interfejs
\end_layout

\begin_layout Standard
Konverzija se izvršava u zasebnoj radnoj niti (
\family typewriter
std::thread
\family default
), pa GUI ostaje responzivan i tokom obrade velikih mreža. Radna nit periodično šalje napredak glavnoj (GUI) niti preko 
\family typewriter
gui::thread::asyncExecInMainThread
\family default
, gdje se ažuriraju progres-indikator i statusna poruka — čime je ispunjen zahtjev prikaza napretka u realnom vremenu na drugoj niti. Izlazni model piše se preko 
\family typewriter
std::ofstream
\family default
, a sadržaj se dodatno upisuje i u izlaznu arhivu (
\family typewriter
put()
\family default
), tako da je dostupan i kroz dTwin okruženje.
\end_layout

