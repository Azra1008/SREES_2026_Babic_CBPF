\begin_layout Subsection
Model mreže
\end_layout

\begin_layout Standard
Sve veličine izražavaju se u relativnim jedinicama (p.u.) u odnosu na baznu snagu 
\begin_inset Formula $S_{base}$
\end_inset

. Grana se modelira standardnom 
\begin_inset Formula $\pi$
\end_inset

-shemom: serijska impedansa 
\begin_inset Formula $r+jx$
\end_inset

, ukupna otočna susceptansa 
\begin_inset Formula $b$
\end_inset

 (po polovina na svakom kraju) i, za transformatorske grane, kompleksni prijenosni odnos 
\begin_inset Formula $a = t\,e^{j\varphi}$
\end_inset

 koji obuhvata i regulaciju modula (
\begin_inset Formula $t$
\end_inset

) i fazni pomak (
\begin_inset Formula $\varphi$
\end_inset

). Otočni elementi čvora (kompenzacija) zadaju se kao 
\begin_inset Formula $G_s + jB_s$
\end_inset

.
\end_layout

\begin_layout Subsection
Matrica admitansi (Y-bus)
\end_layout

\begin_layout Standard
Mreža se kompaktno opisuje matricom admitansi 
\begin_inset Formula $\mathbf{Y}$
\end_inset

, uz vezu 
\begin_inset Formula $\mathbf{I}=\mathbf{Y}\mathbf{V}$
\end_inset

, tj.
\begin_inset space \space{}

\end_inset


\begin_inset Formula $I_i=\sum_k Y_{ik}V_k$
\end_inset

. Za granu 
\begin_inset Formula $f$
\end_inset

–
\begin_inset Formula $t$
\end_inset

 sa serijskom admitansom 
\begin_inset Formula $y=1/(r+jx)$
\end_inset

 i otočnom 
\begin_inset Formula $b_{sh}=j\,b/2$
\end_inset

 doprinosi matrici admitansi glase: 
\begin_inset Formula \begin{equation}
Y_{ff}\mathrel{+}=\frac{y+b_{sh}}{a\,a^{*}},\qquad
Y_{tt}\mathrel{+}=y+b_{sh},\qquad
Y_{ft}\mathrel{+}=-\frac{y}{a^{*}},\qquad
Y_{tf}\mathrel{+}=-\frac{y}{a}.
\label{eq:ybus}
\end{equation}
\end_inset

Otočni elementi čvora 
\begin_inset Formula $(G_s+jB_s)$
\end_inset

 dodaju se na odgovarajući dijagonalni element. Matrica je za realne mreže izrazito rijetka — broj nenultih elemenata raste linearno s brojem grana. U polarnom obliku elementi se zapisuju kao 
\begin_inset Formula $Y_{ik}=Y_{ik}e^{j\theta_{ik}}$
\end_inset

, a naponi kao 
\begin_inset Formula $V_k=V_k e^{j\delta_k}$
\end_inset

.
\end_layout

\begin_layout Subsection
Jednačine strujnog balansa u polarnim koordinatama
\end_layout

\begin_layout Standard
Struja koju čvor 
\begin_inset Formula $i$
\end_inset

 prima iz mreže računa se direktno iz matrice admitansi: 
\begin_inset Formula \begin{equation}
I_i^{calc}=\sum_k Y_{ik}V_k\,e^{j(\theta_{ik}+\delta_k)}
\quad\Longrightarrow\quad
\Re\{I_i^{calc}\}=\sum_k Y_{ik}V_k\cos(\theta_{ik}+\delta_k),\qquad
\Im\{I_i^{calc}\}=\sum_k Y_{ik}V_k\sin(\theta_{ik}+\delta_k).
\label{eq:icalc}
\end{equation}
\end_inset

S druge strane, struja koju čvor 
\begin_inset Quotes eld
\end_inset

traži
\begin_inset Quotes erd
\end_inset

 slijedi iz njegove zadane prividne snage 
\begin_inset Formula $S_i=P_i+jQ_i=V_iI_i^{*}$
\end_inset

: 
\begin_inset Formula \begin{equation}
I_i^{sp}=\left(\frac{S_i}{V_i e^{j\delta_i}}\right)^{*}
        =\frac{P_i-jQ_i}{V_i}\,e^{j\delta_i}.
\label{eq:isp}
\end{equation}
\end_inset

Uslov balansa 
\begin_inset Formula $I_i^{calc}=I_i^{sp}$
\end_inset

, razdvojen na realni i imaginarni dio, daje dvije jednačine po čvoru: 
\begin_inset Formula \begin{align}
\sum_k Y_{ik}V_k\cos(\theta_{ik}+\delta_k) &= \frac{P_i\cos\delta_i+Q_i\sin\delta_i}{V_i},
\label{eq:cbre}\\
\sum_k Y_{ik}V_k\sin(\theta_{ik}+\delta_k) &= \frac{P_i\sin\delta_i-Q_i\cos\delta_i}{V_i}.
\label{eq:cbim}
\end{align}
\end_inset


\end_layout

\begin_layout Subsection
Poređenje s balansom snaga
\end_layout

\begin_layout Standard
Klasična jednačina balansa aktivne snage glasi 
\begin_inset Formula $V_i\sum_k Y_{ik}V_k\cos(\delta_i-\theta_{ik}-\delta_k)=P_i$
\end_inset

 (analogno za 
\begin_inset Formula $Q_i$
\end_inset

). Razlika prema 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:cbre"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

–
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:cbim"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

 je strukturna: kod balansa snaga napon posmatranog čvora 
\begin_inset Formula $V_i$
\end_inset

 množi cijelu sumu, pa se pojavljuje u svakom članu reziduala i svim izvodima; kod balansa struja lijeva strana je 
\emph on
linearna
\emph default
 po svakom 
\begin_inset Formula $V_k$
\end_inset

, a nelinearnost po 
\begin_inset Formula $V_i$
\end_inset

 ograničena je na desnu stranu (član 
\begin_inset Formula $1/V_i$
\end_inset

). Rezidual i Jakobijan su, dakle, izvedeni iz 
\series bold
struja
\series default
, što pojednostavljuje analitičke izvode i implementaciju 
\begin_inset CommandInset citation
LatexCommand cite
after ""
key "cim"
literal "false"

\end_inset

. Obje formulacije imaju identično rješenje — biraju se prema pogodnosti implementacije.
\end_layout

\begin_layout Subsection
Newton–Raphsonova metoda
\end_layout

\begin_layout Standard
Sistem 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:cbre"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

–
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:cbim"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

 zapisuje se kao 
\begin_inset Formula $\mathbf{f}(\mathbf{x})=\mathbf{0}$
\end_inset

 s vektorom nepoznatih 
\begin_inset Formula $\mathbf{x}=[\boldsymbol{\delta},\mathbf{V}]$
\end_inset

 i rješava iterativno 
\begin_inset CommandInset citation
LatexCommand cite
after ""
key "tinney"
literal "false"

\end_inset

: 
\begin_inset Formula \begin{equation}
\mathbf{J}^{(\nu)}\,\Delta\mathbf{x}^{(\nu)}=-\mathbf{f}(\mathbf{x}^{(\nu)}),
\qquad
\mathbf{x}^{(\nu+1)}=\mathbf{x}^{(\nu)}+\Delta\mathbf{x}^{(\nu)},
\label{eq:nr}
\end{equation}
\end_inset

gdje je 
\begin_inset Formula $\mathbf{J}=\partial(\Delta I^{\Re},\Delta I^{\Im})/\partial(\boldsymbol{\delta},\mathbf{V})$
\end_inset

 rijedak Jakobijan iste strukture kao 
\begin_inset Formula $\mathbf{Y}$
\end_inset

. Vandijagonalni izvodi slijede direktno iz 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:icalc"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

 i posebno su jednostavni: 
\begin_inset Formula \begin{equation}
\frac{\partial f_i^{\Re}}{\partial \delta_k}=-Y_{ik}V_k\sin(\theta_{ik}+\delta_k),
\qquad
\frac{\partial f_i^{\Re}}{\partial V_k}=Y_{ik}\cos(\theta_{ik}+\delta_k),
\qquad k\neq i,
\label{eq:jac}
\end{equation}
\end_inset

(analogno za 
\begin_inset Formula $f_i^{\Im}$
\end_inset

, uz zamjenu 
\begin_inset Formula $\sin\leftrightarrow\cos$
\end_inset

 i predznak), dok dijagonalni članovi dobijaju još i doprinos desne strane 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:cbre"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

–
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:cbim"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

. Početna tačka je ravni start (
\begin_inset Formula $V_i=1$
\end_inset


\begin_inset space ~

\end_inset

p.u., 
\begin_inset Formula $\delta_i=0$
\end_inset

), a iteracije se zaustavljaju kada najveći rezidual padne ispod zadane tolerancije. U blizini rješenja konvergencija je kvadratna — broj tačnih cifara se u svakoj iteraciji približno udvostručuje, što je i eksperimentalno potvrđeno u poglavlju
\begin_inset space ~

\end_inset


\begin_inset CommandInset ref
LatexCommand ref
reference "sec:rezultati"
plural "false"
caps "false"
noprefix "false"
nolink "false"
tuple "list"

\end_inset

.
\end_layout

