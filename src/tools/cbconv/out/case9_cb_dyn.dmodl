NLEs:
	// čvor 2 - PV
	Y_2_2*V_2^2*cos(θ_2_2) + V_2*(Y_2_8*V_8*cos(δ_2-θ_2_8-δ_8)) = P_2_g
	V_2 = V_2_sp
	// čvor 3 - PV
	Y_3_3*V_3^2*cos(θ_3_3) + V_3*(Y_3_6*V_6*cos(δ_3-θ_3_6-δ_6)) = P_3_g
	V_3 = V_3_sp
	// čvor 4 - PQ (ZI)
	Y_4_4*V_4*cos(θ_4_4) + Y_4_1*V_1_init*cos(δ_4-θ_4_1-δ_1_init) + Y_4_5*V_5*cos(δ_4-θ_4_5-δ_5) + Y_4_9*V_9*cos(δ_4-θ_4_9-δ_9) = 0
	-Y_4_4*V_4*sin(θ_4_4) + Y_4_1*V_1_init*sin(δ_4-θ_4_1-δ_1_init) + Y_4_5*V_5*sin(δ_4-θ_4_5-δ_5) + Y_4_9*V_9*sin(δ_4-θ_4_9-δ_9) = 0
	// čvor 5 - PQ
	Y_5_5*V_5^2*cos(θ_5_5) + V_5*(Y_5_4*V_4*cos(δ_5-θ_5_4-δ_4) + Y_5_6*V_6*cos(δ_5-θ_5_6-δ_6)) = P_5
	-Y_5_5*V_5^2*sin(θ_5_5) + V_5*(Y_5_4*V_4*sin(δ_5-θ_5_4-δ_4) + Y_5_6*V_6*sin(δ_5-θ_5_6-δ_6)) = Q_5
	// čvor 6 - PQ (ZI)
	Y_6_6*V_6*cos(θ_6_6) + Y_6_3*V_3*cos(δ_6-θ_6_3-δ_3) + Y_6_5*V_5*cos(δ_6-θ_6_5-δ_5) + Y_6_7*V_7*cos(δ_6-θ_6_7-δ_7) = 0
	-Y_6_6*V_6*sin(θ_6_6) + Y_6_3*V_3*sin(δ_6-θ_6_3-δ_3) + Y_6_5*V_5*sin(δ_6-θ_6_5-δ_5) + Y_6_7*V_7*sin(δ_6-θ_6_7-δ_7) = 0
	// čvor 7 - PQ
	Y_7_7*V_7^2*cos(θ_7_7) + V_7*(Y_7_6*V_6*cos(δ_7-θ_7_6-δ_6) + Y_7_8*V_8*cos(δ_7-θ_7_8-δ_8)) = P_7
	-Y_7_7*V_7^2*sin(θ_7_7) + V_7*(Y_7_6*V_6*sin(δ_7-θ_7_6-δ_6) + Y_7_8*V_8*sin(δ_7-θ_7_8-δ_8)) = Q_7
	// čvor 8 - PQ (ZI)
	Y_8_8*V_8*cos(θ_8_8) + Y_8_2*V_2*cos(δ_8-θ_8_2-δ_2) + Y_8_7*V_7*cos(δ_8-θ_8_7-δ_7) + Y_8_9*V_9*cos(δ_8-θ_8_9-δ_9) = 0
	-Y_8_8*V_8*sin(θ_8_8) + Y_8_2*V_2*sin(δ_8-θ_8_2-δ_2) + Y_8_7*V_7*sin(δ_8-θ_8_7-δ_7) + Y_8_9*V_9*sin(δ_8-θ_8_9-δ_9) = 0
	// čvor 9 - PQ
	Y_9_9*V_9^2*cos(θ_9_9) + V_9*(Y_9_4*V_4*cos(δ_9-θ_9_4-δ_4) + Y_9_8*V_8*cos(δ_9-θ_9_8-δ_8)) = P_9
	-Y_9_9*V_9^2*sin(θ_9_9) + V_9*(Y_9_4*V_4*sin(δ_9-θ_9_4-δ_4) + Y_9_8*V_8*sin(δ_9-θ_9_8-δ_8)) = Q_9
PostProc:
	// --- inicijalizacija generatora na čvoru 1 ---
	P_1_init = Y_1_1*V_1_init^2*cos(θ_1_1) + V_1_init*(Y_1_4*V_4*cos(δ_1_init-θ_1_4-δ_4))
	Q_1_init = -Y_1_1*V_1_init^2*sin(θ_1_1) + V_1_init*(Y_1_4*V_4*sin(δ_1_init-θ_1_4-δ_4))
	I_r1_init = (P_1_init*cos(δ_1_init) + Q_1_init*sin(δ_1_init))/V_1_init
	I_i1_init = (P_1_init*sin(δ_1_init) - Q_1_init*cos(δ_1_init))/V_1_init
	Eq_r1_init = V_1_init*cos(δ_1_init) + Rs_g1*I_r1_init - Xq_g1*I_i1_init
	Eq_i1_init = V_1_init*sin(δ_1_init) + Rs_g1*I_i1_init + Xq_g1*I_r1_init
	@main.δ_g1 = atg2(Eq_r1_init, Eq_i1_init)
	I_d1_init = I_r1_init*sin(@main.δ_g1) - I_i1_init*cos(@main.δ_g1)
	I_q1_init = I_r1_init*cos(@main.δ_g1) + I_i1_init*sin(@main.δ_g1)
	V_d1_init = V_1_init*sin(@main.δ_g1 - δ_1_init)
	V_q1_init = V_1_init*cos(@main.δ_g1 - δ_1_init)
	E_d1_p_init = (Xq_g1 - Xq_p_g1) * I_q1_init
	E_q1_p_init = V_q1_init + Rs_g1 * I_q1_init + Xd_p_g1 * I_d1_init
	Ef_d1_init = E_q1_p_init + (Xd_g1 - Xd_p_g1)*I_d1_init
	VR1_init = (Ke_g1 + Se_g1) * Ef_d1_init
	Rf1_init = (Kf_g1 / Tf_g1) * Ef_d1_init
	Vref1_init = V_1_init + (VR1_init / Ka_g1)
	@main.ω_g1 = ω_ref
	@main.Ed_p_g1 = E_d1_p_init
	@main.Eq_p_g1 = E_q1_p_init
	@main.VR_g1 = VR1_init
	@main.Rf_g1 = Rf1_init
	@main.Id_g1 = I_d1_init
	@main.Iq_g1 = I_q1_init
	@main.Efd_g1 = Ef_d1_init
	@main.Vref_g1 = Vref1_init
	Tm1_init = @main.Ed_p_g1*I_d1_init + @main.Eq_p_g1*I_q1_init + (Xq_p_g1 - Xd_p_g1)*I_d1_init*I_q1_init
	@main.Pe_g1 = Tm1_init
	@main.P_gm_g1 = Tm1_init
	@main.Tm_g1 = Tm1_init
	@main.Q_1 = Q_1_init; @main.P_1 = P_1_init
	// --- inicijalizacija generatora na čvoru 2 ---
	P_2_init = P_2_g
	Q_2_init = -Y_2_2*V_2^2*sin(θ_2_2) + V_2*(Y_2_8*V_8*sin(δ_2-θ_2_8-δ_8))
	I_r2_init = (P_2_init*cos(δ_2) + Q_2_init*sin(δ_2))/V_2
	I_i2_init = (P_2_init*sin(δ_2) - Q_2_init*cos(δ_2))/V_2
	Eq_r2_init = V_2*cos(δ_2) + Rs_g2*I_r2_init - Xq_g2*I_i2_init
	Eq_i2_init = V_2*sin(δ_2) + Rs_g2*I_i2_init + Xq_g2*I_r2_init
	@main.δ_g2 = atg2(Eq_r2_init, Eq_i2_init)
	I_d2_init = I_r2_init*sin(@main.δ_g2) - I_i2_init*cos(@main.δ_g2)
	I_q2_init = I_r2_init*cos(@main.δ_g2) + I_i2_init*sin(@main.δ_g2)
	V_d2_init = V_2*sin(@main.δ_g2 - δ_2)
	V_q2_init = V_2*cos(@main.δ_g2 - δ_2)
	E_d2_p_init = (Xq_g2 - Xq_p_g2) * I_q2_init
	E_q2_p_init = V_q2_init + Rs_g2 * I_q2_init + Xd_p_g2 * I_d2_init
	Ef_d2_init = E_q2_p_init + (Xd_g2 - Xd_p_g2)*I_d2_init
	VR2_init = (Ke_g2 + Se_g2) * Ef_d2_init
	Rf2_init = (Kf_g2 / Tf_g2) * Ef_d2_init
	Vref2_init = V_2 + (VR2_init / Ka_g2)
	@main.ω_g2 = ω_ref
	@main.Ed_p_g2 = E_d2_p_init
	@main.Eq_p_g2 = E_q2_p_init
	@main.VR_g2 = VR2_init
	@main.Rf_g2 = Rf2_init
	@main.Id_g2 = I_d2_init
	@main.Iq_g2 = I_q2_init
	@main.Efd_g2 = Ef_d2_init
	@main.Vref_g2 = Vref2_init
	Tm2_init = @main.Ed_p_g2*I_d2_init + @main.Eq_p_g2*I_q2_init + (Xq_p_g2 - Xd_p_g2)*I_d2_init*I_q2_init
	@main.Pe_g2 = Tm2_init
	@main.P_gm_g2 = Tm2_init
	@main.Tm_g2 = Tm2_init
	@main.Q_2_g = Q_2_init; @main.P_2_g = P_2_init
	// --- inicijalizacija generatora na čvoru 3 ---
	P_3_init = P_3_g
	Q_3_init = -Y_3_3*V_3^2*sin(θ_3_3) + V_3*(Y_3_6*V_6*sin(δ_3-θ_3_6-δ_6))
	I_r3_init = (P_3_init*cos(δ_3) + Q_3_init*sin(δ_3))/V_3
	I_i3_init = (P_3_init*sin(δ_3) - Q_3_init*cos(δ_3))/V_3
	Eq_r3_init = V_3*cos(δ_3) + Rs_g3*I_r3_init - Xq_g3*I_i3_init
	Eq_i3_init = V_3*sin(δ_3) + Rs_g3*I_i3_init + Xq_g3*I_r3_init
	@main.δ_g3 = atg2(Eq_r3_init, Eq_i3_init)
	I_d3_init = I_r3_init*sin(@main.δ_g3) - I_i3_init*cos(@main.δ_g3)
	I_q3_init = I_r3_init*cos(@main.δ_g3) + I_i3_init*sin(@main.δ_g3)
	V_d3_init = V_3*sin(@main.δ_g3 - δ_3)
	V_q3_init = V_3*cos(@main.δ_g3 - δ_3)
	E_d3_p_init = (Xq_g3 - Xq_p_g3) * I_q3_init
	E_q3_p_init = V_q3_init + Rs_g3 * I_q3_init + Xd_p_g3 * I_d3_init
	Ef_d3_init = E_q3_p_init + (Xd_g3 - Xd_p_g3)*I_d3_init
	VR3_init = (Ke_g3 + Se_g3) * Ef_d3_init
	Rf3_init = (Kf_g3 / Tf_g3) * Ef_d3_init
	Vref3_init = V_3 + (VR3_init / Ka_g3)
	@main.ω_g3 = ω_ref
	@main.Ed_p_g3 = E_d3_p_init
	@main.Eq_p_g3 = E_q3_p_init
	@main.VR_g3 = VR3_init
	@main.Rf_g3 = Rf3_init
	@main.Id_g3 = I_d3_init
	@main.Iq_g3 = I_q3_init
	@main.Efd_g3 = Ef_d3_init
	@main.Vref_g3 = Vref3_init
	Tm3_init = @main.Ed_p_g3*I_d3_init + @main.Eq_p_g3*I_q3_init + (Xq_p_g3 - Xd_p_g3)*I_d3_init*I_q3_init
	@main.Pe_g3 = Tm3_init
	@main.P_gm_g3 = Tm3_init
	@main.Tm_g3 = Tm3_init
	@main.Q_3_g = Q_3_init; @main.P_3_g = P_3_init
	@main.δ_1 = δ_1_init; @main.V_1 = V_1_init
	@main.δ_2 = δ_2; @main.V_2 = V_2
	@main.δ_3 = δ_3; @main.V_3 = V_3
	@main.δ_4 = δ_4; @main.V_4 = V_4
	@main.δ_5 = δ_5; @main.V_5 = V_5
	@main.δ_6 = δ_6; @main.V_6 = V_6
	@main.δ_7 = δ_7; @main.V_7 = V_7
	@main.δ_8 = δ_8; @main.V_8 = V_8
	@main.δ_9 = δ_9; @main.V_9 = V_9
end
ODEs:
	// generator na čvoru 1
	Eq_p_g1' = (-Eq_p_g1 - (Xd_g1 - Xd_p_g1)*Id_g1 + Efd_g1)/Tdo_p_g1
	Ed_p_g1' = (-Ed_p_g1 + (Xq_g1 - Xq_p_g1)*Iq_g1)/Tqo_p_g1
	δ_g1' = (ω_g1 - ω_ref) * ω_s
	ω_g1' = (P_gm_g1 - (Ed_p_g1 * Id_g1 + Eq_p_g1 * Iq_g1 + (Xq_p_g1 - Xd_p_g1) * Id_g1 * Iq_g1) - D_g1*(ω_g1 - ω_ref)) * ω_s /(2*H_g1)
	Efd_g1' = (-(Ke_g1 + Se_g1)*Efd_g1 + VR_g1)/Te_g1
	Rf_g1' = (-Rf_g1 + (Kf_g1/Tf_g1)*Efd_g1)/Tf_g1
	VR_g1' = (-VR_g1 + Ka_g1*Rf_g1 - (Ka_g1*Kf_g1/Tf_g1)*Efd_g1 + Ka_g1*(Vref_g1 - V_1))/Ta_g1
	P_gm_g1' = (ω_ref - ω_g1) / (T_gov_g1 * R_g1 * ω_ref)
	// generator na čvoru 2
	Eq_p_g2' = (-Eq_p_g2 - (Xd_g2 - Xd_p_g2)*Id_g2 + Efd_g2)/Tdo_p_g2
	Ed_p_g2' = (-Ed_p_g2 + (Xq_g2 - Xq_p_g2)*Iq_g2)/Tqo_p_g2
	δ_g2' = (ω_g2 - ω_ref) * ω_s
	ω_g2' = (P_gm_g2 - (Ed_p_g2 * Id_g2 + Eq_p_g2 * Iq_g2 + (Xq_p_g2 - Xd_p_g2) * Id_g2 * Iq_g2) - D_g2*(ω_g2 - ω_ref)) * ω_s /(2*H_g2)
	Efd_g2' = (-(Ke_g2 + Se_g2)*Efd_g2 + VR_g2)/Te_g2
	Rf_g2' = (-Rf_g2 + (Kf_g2/Tf_g2)*Efd_g2)/Tf_g2
	VR_g2' = (-VR_g2 + Ka_g2*Rf_g2 - (Ka_g2*Kf_g2/Tf_g2)*Efd_g2 + Ka_g2*(Vref_g2 - V_2))/Ta_g2
	P_gm_g2' = (ω_ref - ω_g2) / (T_gov_g2 * R_g2 * ω_ref)
	// generator na čvoru 3
	Eq_p_g3' = (-Eq_p_g3 - (Xd_g3 - Xd_p_g3)*Id_g3 + Efd_g3)/Tdo_p_g3
	Ed_p_g3' = (-Ed_p_g3 + (Xq_g3 - Xq_p_g3)*Iq_g3)/Tqo_p_g3
	δ_g3' = (ω_g3 - ω_ref) * ω_s
	ω_g3' = (P_gm_g3 - (Ed_p_g3 * Id_g3 + Eq_p_g3 * Iq_g3 + (Xq_p_g3 - Xd_p_g3) * Id_g3 * Iq_g3) - D_g3*(ω_g3 - ω_ref)) * ω_s /(2*H_g3)
	Efd_g3' = (-(Ke_g3 + Se_g3)*Efd_g3 + VR_g3)/Te_g3
	Rf_g3' = (-Rf_g3 + (Kf_g3/Tf_g3)*Efd_g3)/Tf_g3
	VR_g3' = (-VR_g3 + Ka_g3*Rf_g3 - (Ka_g3*Kf_g3/Tf_g3)*Efd_g3 + Ka_g3*(Vref_g3 - V_3))/Ta_g3
	P_gm_g3' = (ω_ref - ω_g3) / (T_gov_g3 * R_g3 * ω_ref)
NLEs:
	// statorske jednačine (d-q struje)
	Id_g1 = (Rs_g1 * (Ed_p_g1 - V_1 * sin(δ_g1 - δ_1)) + Xq_p_g1 * (Eq_p_g1 - V_1 * cos(δ_g1 - δ_1))) / (Rs_g1^2 + Xd_p_g1 * Xq_p_g1)
	Iq_g1 = (-Xd_p_g1 * (Ed_p_g1 - V_1 * sin(δ_g1 - δ_1)) + Rs_g1 * (Eq_p_g1 - V_1 * cos(δ_g1 - δ_1))) / (Rs_g1^2 + Xd_p_g1 * Xq_p_g1)
	Id_g2 = (Rs_g2 * (Ed_p_g2 - V_2 * sin(δ_g2 - δ_2)) + Xq_p_g2 * (Eq_p_g2 - V_2 * cos(δ_g2 - δ_2))) / (Rs_g2^2 + Xd_p_g2 * Xq_p_g2)
	Iq_g2 = (-Xd_p_g2 * (Ed_p_g2 - V_2 * sin(δ_g2 - δ_2)) + Rs_g2 * (Eq_p_g2 - V_2 * cos(δ_g2 - δ_2))) / (Rs_g2^2 + Xd_p_g2 * Xq_p_g2)
	Id_g3 = (Rs_g3 * (Ed_p_g3 - V_3 * sin(δ_g3 - δ_3)) + Xq_p_g3 * (Eq_p_g3 - V_3 * cos(δ_g3 - δ_3))) / (Rs_g3^2 + Xd_p_g3 * Xq_p_g3)
	Iq_g3 = (-Xd_p_g3 * (Ed_p_g3 - V_3 * sin(δ_g3 - δ_3)) + Rs_g3 * (Eq_p_g3 - V_3 * cos(δ_g3 - δ_3))) / (Rs_g3^2 + Xd_p_g3 * Xq_p_g3)
	// električna snaga generatora
	Pe_g1 = Ed_p_g1 * Id_g1 + Eq_p_g1 * Iq_g1 + (Xq_p_g1 - Xd_p_g1) * Id_g1 * Iq_g1
	Pe_g2 = Ed_p_g2 * Id_g2 + Eq_p_g2 * Iq_g2 + (Xq_p_g2 - Xd_p_g2) * Id_g2 * Iq_g2
	Pe_g3 = Ed_p_g3 * Id_g3 + Eq_p_g3 * Iq_g3 + (Xq_p_g3 - Xd_p_g3) * Id_g3 * Iq_g3
	// mrežni čvorovi (strujni balans u polarnim koordinatama)
	// čvor 1 - generator (injekcija struje = struja u mrežu)
	V_1*(Id_g1*sin(δ_g1 - δ_1) + Iq_g1*cos(δ_g1 - δ_1)) = Y_1_1*V_1^2*cos(θ_1_1) + V_1*(Y_1_4*V_4*cos(δ_1-θ_1_4-δ_4))
	V_1*(Id_g1*cos(δ_g1 - δ_1) - Iq_g1*sin(δ_g1 - δ_1)) = -Y_1_1*V_1^2*sin(θ_1_1) + V_1*(Y_1_4*V_4*sin(δ_1-θ_1_4-δ_4))
	// čvor 2 - generator (injekcija struje = struja u mrežu)
	V_2*(Id_g2*sin(δ_g2 - δ_2) + Iq_g2*cos(δ_g2 - δ_2)) = Y_2_2*V_2^2*cos(θ_2_2) + V_2*(Y_2_8*V_8*cos(δ_2-θ_2_8-δ_8))
	V_2*(Id_g2*cos(δ_g2 - δ_2) - Iq_g2*sin(δ_g2 - δ_2)) = -Y_2_2*V_2^2*sin(θ_2_2) + V_2*(Y_2_8*V_8*sin(δ_2-θ_2_8-δ_8))
	// čvor 3 - generator (injekcija struje = struja u mrežu)
	V_3*(Id_g3*sin(δ_g3 - δ_3) + Iq_g3*cos(δ_g3 - δ_3)) = Y_3_3*V_3^2*cos(θ_3_3) + V_3*(Y_3_6*V_6*cos(δ_3-θ_3_6-δ_6))
	V_3*(Id_g3*cos(δ_g3 - δ_3) - Iq_g3*sin(δ_g3 - δ_3)) = -Y_3_3*V_3^2*sin(θ_3_3) + V_3*(Y_3_6*V_6*sin(δ_3-θ_3_6-δ_6))
	// čvor 4 - PQ (ZI)
	Y_4_4*V_4*cos(θ_4_4) + Y_4_1*V_1*cos(δ_4-θ_4_1-δ_1) + Y_4_5*V_5*cos(δ_4-θ_4_5-δ_5) + Y_4_9*V_9*cos(δ_4-θ_4_9-δ_9) = 0
	-Y_4_4*V_4*sin(θ_4_4) + Y_4_1*V_1*sin(δ_4-θ_4_1-δ_1) + Y_4_5*V_5*sin(δ_4-θ_4_5-δ_5) + Y_4_9*V_9*sin(δ_4-θ_4_9-δ_9) = 0
	// čvor 5 - PQ
	Y_5_5*V_5^2*cos(θ_5_5) + V_5*(Y_5_4*V_4*cos(δ_5-θ_5_4-δ_4) + Y_5_6*V_6*cos(δ_5-θ_5_6-δ_6)) = P_5
	-Y_5_5*V_5^2*sin(θ_5_5) + V_5*(Y_5_4*V_4*sin(δ_5-θ_5_4-δ_4) + Y_5_6*V_6*sin(δ_5-θ_5_6-δ_6)) = Q_5
	// čvor 6 - PQ (ZI)
	Y_6_6*V_6*cos(θ_6_6) + Y_6_3*V_3*cos(δ_6-θ_6_3-δ_3) + Y_6_5*V_5*cos(δ_6-θ_6_5-δ_5) + Y_6_7*V_7*cos(δ_6-θ_6_7-δ_7) = 0
	-Y_6_6*V_6*sin(θ_6_6) + Y_6_3*V_3*sin(δ_6-θ_6_3-δ_3) + Y_6_5*V_5*sin(δ_6-θ_6_5-δ_5) + Y_6_7*V_7*sin(δ_6-θ_6_7-δ_7) = 0
	// čvor 7 - PQ
	Y_7_7*V_7^2*cos(θ_7_7) + V_7*(Y_7_6*V_6*cos(δ_7-θ_7_6-δ_6) + Y_7_8*V_8*cos(δ_7-θ_7_8-δ_8)) = P_7
	-Y_7_7*V_7^2*sin(θ_7_7) + V_7*(Y_7_6*V_6*sin(δ_7-θ_7_6-δ_6) + Y_7_8*V_8*sin(δ_7-θ_7_8-δ_8)) = Q_7
	// čvor 8 - PQ (ZI)
	Y_8_8*V_8*cos(θ_8_8) + Y_8_2*V_2*cos(δ_8-θ_8_2-δ_2) + Y_8_7*V_7*cos(δ_8-θ_8_7-δ_7) + Y_8_9*V_9*cos(δ_8-θ_8_9-δ_9) = 0
	-Y_8_8*V_8*sin(θ_8_8) + Y_8_2*V_2*sin(δ_8-θ_8_2-δ_2) + Y_8_7*V_7*sin(δ_8-θ_8_7-δ_7) + Y_8_9*V_9*sin(δ_8-θ_8_9-δ_9) = 0
	// čvor 9 - PQ
	Y_9_9*V_9^2*cos(θ_9_9) + V_9*(Y_9_4*V_4*cos(δ_9-θ_9_4-δ_4) + Y_9_8*V_8*cos(δ_9-θ_9_8-δ_8)) = P_9
	-Y_9_9*V_9^2*sin(θ_9_9) + V_9*(Y_9_4*V_4*sin(δ_9-θ_9_4-δ_4) + Y_9_8*V_8*sin(δ_9-θ_9_8-δ_8)) = Q_9
PostProc:
	// SMETNJA: ispad opterećenja na čvoru 5 od t=0.5s do t=6s
	if t >= 0.5:
		if t < 6:
			P_5 = 0; Q_5 = 0
		else:
			P_5 = -0.9; Q_5 = -0.3
		end
	end
end
